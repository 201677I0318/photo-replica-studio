# 照片分析 API，仅供服务端读取；不要提交真实密钥
OPENAI_API_KEY=your-api-key

# API 地址通常以 /v1 结尾
OPENAI_BASE_URL=https://api.openai.com/v1

# 分析模型；请替换为 API 服务实际开放且支持视觉输入的模型
OPENAI_MODEL=gpt-5.6-terra

# responses（推荐）或 chat（兼容仅实现 Chat Completions 的服务）
OPENAI_API_MODE=responses

# high 兼容面更广；模型支持时可改为 original
OPENAI_IMAGE_DETAIL=high

# AI 修图与同风格生图 API；留空时分别回退到 OPENAI_API_KEY / OPENAI_BASE_URL
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=

# gpt-image-2 使用 Images Edit 流式传输
OPENAI_IMAGE_MODEL=gpt-image-2

# low / medium / high，medium 是速度、成本和细节的平衡点
OPENAI_IMAGE_QUALITY=medium

# 上游连续无新事件的超时时间；收到局部图或完成事件后会重新计时
IMAGE_GENERATION_INACTIVITY_TIMEOUT_MS=300000

# 分析推理强度
OPENAI_REASONING_EFFORT=medium

# 单次分析最长等待时间，默认 4 分钟
ANALYSIS_TIMEOUT_MS=240000

# 部分兼容服务会拦截 SDK 默认请求头；一般保持 node 即可
OPENAI_USER_AGENT=node

PORT=8787
